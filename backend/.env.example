# --- Required ---
DATABASE_URL=postgres://postgres:password@localhost:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# --- Server ---
HOST=0.0.0.0
SERVER_PORT=8080

# --- Database Pool ---
DB_POOL_MIN=1
DB_POOL_MAX=5
DB_ACQUIRE_TIMEOUT_SECS=30
DB_TEST_BEFORE_ACQUIRE=false

# --- Matching Weights ---
WEIGHT_DEMO=0.30
WEIGHT_ACADEMIC=0.30
WEIGHT_NEED=0.25
WEIGHT_EXTRA=0.15

# --- Matching Scheduler ---
MATCHING_INTERVAL_MINUTES=30
DEPARTMENT_SIMILARITY_THRESHOLD=0.8

# --- CORS (comma-separated origins; use * for all) ---
ALLOWED_ORIGINS=*

# --- Logging ---
LOG_LEVEL=info
